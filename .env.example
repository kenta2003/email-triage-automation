# Slack Incoming Webhook URLs
# Example: https://hooks.slack.com/services/XXX/YYY/ZZZ
SLACK_PRIMARY_REPLY_WEBHOOK=
SLACK_PRIMARY_DIGEST_WEBHOOK=
SLACK_SECONDARY_REPLY_WEBHOOK=
SLACK_SECONDARY_DIGEST_WEBHOOK=

# Claude Code CLI
# Specify the binary path when PATH is not resolved (e.g. Windows Task Scheduler)
# Windows example: C:\Users\<you>\AppData\Local\Programs\Claude\claude.cmd
CLAUDE_BIN=claude
